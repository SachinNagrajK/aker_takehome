# --- Database ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=property_user
MYSQL_PASSWORD=property_pass
MYSQL_DB=property_ai

# Read-only user for LLM-written SQL via execute_scoped_sql (v2).
# Only SELECT on the rent-roll tables. Defense-in-depth even if sqlglot is fooled.
MYSQL_READER_USER=property_reader
MYSQL_READER_PASSWORD=reader_pass

# --- LLM Providers (set the ones you have; others will be reported as unavailable) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- Vector store (v1 — legacy) ---
CHROMA_DIR=./chroma_db
EMBEDDING_MODEL=text-embedding-3-small

# --- Vector store (v2 — docling + Jina v4 multimodal) ---
RAG_VERSION=v2
CHROMA_DIR_V2=./chroma_db_v2
COLLECTION_V2=property_chunks_v2
DOC_STORE_DIR=./doc_store
EMBEDDING_MODEL_V2=jinaai/jina-clip-v2
EMBEDDING_QUANT=fp32

# Required for POST /admin/ingest (sent as X-Admin-Token header)
ADMIN_TOKEN=change-me

# --- Data ---
RENT_ROLL_DIR=../../RentRoll_LeaseCharges_NamesRedacted/RentRoll_LeaseCharges_NamesRedacted

# --- Server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
