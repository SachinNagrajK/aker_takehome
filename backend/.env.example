# --- Database (Postgres) ---
# Single canonical URL. Supabase gives you this in Project Settings → Database.
# For the Supabase pooler use port 6543 instead of 5432.
# Format: postgresql+psycopg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+psycopg://property_user:property_pass@localhost:5432/property_ai

# Read-only role — used only by the LLM-written SQL executor.
# Lacks INSERT/UPDATE/DELETE/DDL privileges at the Postgres level even if
# the sqlglot validator is bypassed.
DATABASE_READER_URL=postgresql+psycopg://property_reader:reader_pass@localhost:5432/property_ai

# --- LLM Providers (set the ones you have; others will be reported as unavailable) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- Vector store (Pinecone serverless, free starter tier) ---
RAG_VERSION=v2
PINECONE_API_KEY=
PINECONE_INDEX=property-chunks-v2
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# --- Embeddings (Jina-CLIP-v2 ONNX, run locally) ---
DOC_STORE_DIR=./doc_store
EMBEDDING_MODEL_V2=jinaai/jina-clip-v2
EMBEDDING_QUANT=fp32

# Required for POST /admin/ingest (sent as X-Admin-Token header)
ADMIN_TOKEN=change-me

# --- Data ---
RENT_ROLL_DIR=../../RentRoll_LeaseCharges_NamesRedacted/RentRoll_LeaseCharges_NamesRedacted

# --- Server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
