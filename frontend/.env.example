# Set this in Vercel (Project Settings → Environment Variables) to the
# Hugging Face Space URL for the backend, e.g.
#
#   VITE_API_BASE=https://sachinkulk-aker-property-ai.hf.space
#
# When unset (local dev), the Vite proxy in vite.config.js forwards /api/*
# to http://127.0.0.1:8000 instead.
VITE_API_BASE=
